PORT=8080
BASE_URL=http://localhost:8080
APP_ENV=dev
DB_TYPE=sqlite
DB_PATH=/var/www/html/data/app.db
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
MAIL_FROM=noreply@hookpool.com
MAIL_FROM_NAME=Hookpool
ADMIN_EMAIL=
TOKEN_EXPIRY_HOURS=72
DEFAULT_LANG=en
HOOKPOOL_AUTH=no
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=
CRON_SECRET=
# Comma-separated list of HTTP header names to ignore (not saved, not displayed).
# Matching is case-insensitive. Example: X-Forwarded-For,X-Real-Ip,Cookie
HOOKPOOL_IGNORED_HEADERS=
