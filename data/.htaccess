# Copy this file to  data/.htaccess
# Deny all direct HTTP access to this directory.
# Files here (database, uploads, emails) must only be accessed by PHP, never via the web.
<IfModule mod_authz_core.c>
    Require all denied
</IfModule>
<IfModule !mod_authz_core.c>
    Order deny,allow
    Deny from all
</IfModule>
